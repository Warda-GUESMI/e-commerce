# Example environment file
# Copier ce fichier en .env et remplir les valeurs

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=10000

# Stripe Payment Gateway
VITE_STRIPE_PUBLIC_KEY=pk_test_your_test_key_here

# SendGrid Email Service (optional)
VITE_SENDGRID_API_KEY=your_sendgrid_api_key

# Application Settings
VITE_ENV=development
VITE_APP_NAME=Technova
VITE_PROMO_CODE=TECHNOVA2026
VITE_APP_DESCRIPTION=Votre spécialiste en matériel informatique en Tunisie

# Debug
VITE_DEBUG=false
